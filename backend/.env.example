# Backend configuration. Copy to .env and adjust as needed.

# CORS + invite-link generation
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Database — leave unset for a local SQLite file.
# In production, set to your Postgres connection string:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# The single implicit user (the app intentionally has no authentication)
DEFAULT_USER_NAME=Demo User
DEFAULT_USER_EMAIL=demo@zoomclone.app

# Directory where uploaded meeting recordings are stored
RECORDINGS_DIR=recordings

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
